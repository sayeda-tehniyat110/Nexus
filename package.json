{
  "name": "nexus",
  "version": "0.1.0",
  "description": "NEXUS - Windows-native autonomous AI agent",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:app\"",
    "dev:ui": "cd packages/ui && npm run dev",
    "dev:app": "cd packages/app && npm run dev",
    "build": "npm run build:shared && npm run build:agent && npm run build:pc-control && npm run build:ui && npm run build:app",
    "build:shared": "cd shared && npm run build",
    "build:agent": "cd packages/agent && npm run build",
    "build:pc-control": "cd packages/pc-control && npm run build",
    "build:ui": "cd packages/ui && npm run build",
    "build:app": "cd packages/app && npm run build",
    "build:installer": "cd packages/app && npm run build:installer",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "windows",
    "electron",
    "claude",
    "gpt"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@google/generative-ai": "^0.24.1",
    "openai": "^6.36.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "zod": "^4.4.3"
  }
}
